# Database
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=caradvisor
POSTGRES_PASSWORD=caradvisor_dev
POSTGRES_DB=caradvisor
DB_POOL_MAX=10

# API
API_PORT=3100
CORS_ORIGIN=http://localhost:5274

# OVH AI Endpoints (OpenAI-compatible)
# Generate a key: OVHcloud Manager → Public Cloud → AI & ML → AI Endpoints → API keys
OVH_AI_ENDPOINTS_API_KEY=your_ovh_ai_endpoints_key_here
# Optional override (defaults to https://oai.endpoints.kepler.ai.cloud.ovh.net/v1)
# OVH_AI_ENDPOINTS_BASE_URL=

# Node
NODE_ENV=development

# Logging
LOG_LEVEL=debug

# Sentry (optional — leave empty to disable)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
